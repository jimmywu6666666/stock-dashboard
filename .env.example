APP_PORT=3000
ACCESS_USERNAME=admin
ACCESS_PASSWORD=请改成强密码
SESSION_SECRET=请改成一串至少32位随机字符

# AI 分析服务。Docker Compose 内部默认使用 stock-dsa 服务名。
DSA_API_BASE_URL=http://stock-dsa:8000
DSA_REPORT_LANGUAGE=zh

# DSA LLM：腾讯云 TokenHub / OpenAI-compatible
OPENAI_API_KEY=
OPENAI_BASE_URL=https://tokenhub.tencentmaas.com/v1
OPENAI_MODEL=deepseek-v4-flash-202605
LITELLM_MODEL=openai/deepseek-v4-flash-202605
REPORT_LANGUAGE=zh

# 截图识别三选一：腾讯云 OCR、OpenAI 或自定义 OCR
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_REGION=ap-guangzhou
TENCENT_OCR_ACTION=GeneralAccurateOCR
OCR_API_URL=
OCR_API_KEY=

# 自选股收盘日报。当前使用邮箱发送。
PUBLIC_BASE_URL=https://stock.ou7.cc
DAILY_REPORT_TIME=16:30

# 邮箱日报 SMTP。REPORT_SMTP_PASS 通常是邮箱授权码，不是网页登录密码。
REPORT_SMTP_HOST=
REPORT_SMTP_PORT=465
REPORT_SMTP_SECURE=true
REPORT_SMTP_USER=
REPORT_SMTP_PASS=
REPORT_EMAIL_FROM=

# 如需开放注册
ALLOW_SIGNUP=false
SIGNUP_CODE=

# Tushare / 国家队持仓透视
TUSHARE_TOKEN=
TUSHARE_API_URL=https://api.tushare.pro
NT_KEYWORDS=中央汇金,汇金资产,中国证券金融,证金,全国社保基金,社保基金,基本养老保险基金,梧桐树投资,国新投资,国家集成电路
NT_REFRESH_LIMIT=120
NT_COST_DISCOUNT=0.95
NT_AUTO_REFRESH_ENABLED=true
NT_DAILY_REFRESH_TIME=20:30
NT_REFRESH_RETRY_COUNT=3
NT_REFRESH_RETRY_DELAY_MS=900000
